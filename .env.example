# Railway injeta PORT automaticamente.
# Escolha: dashboard, bot ou all
RAILWAY_SERVICE_MODE=dashboard

# Runtime principal
TESTNET=true
SYMBOL=BTC/USDT
TIMEFRAME=15m
SINGLE_USER_RUNTIME_EXCHANGE=binanceusdm
SINGLE_USER_RUNTIME_ACCOUNT_ID=railway-primary
SINGLE_USER_RUNTIME_ACCOUNT_ALIAS=Railway Primary
BOT_REQUIRE_LOCAL_CSV_BOOTSTRAP=false
BOT_ALLOW_REST_FALLBACK=true
LEVERAGE=10
POSITION_SIZING_MODE=risk
RISK_PER_TRADE_PCT=2
POSITION_MARGIN_ALLOCATION_PCT=25
MAX_DAILY_REAL_LOSS_PCT=2
MAX_CONSECUTIVE_REAL_LOSSES=3
RISK_DRAWDOWN_WARNING_PCT=8
RISK_DRAWDOWN_BLOCK_PCT=12

# Persistencia
# Em producao, prefira adicionar Railway Postgres e preencher DATABASE_URL.
DATABASE_URL=
DB_PATH=data/trading_bot.db

# Dashboard / acesso
ADMIN_PANEL_PASSWORD=troque-esta-senha
ALLOW_SELF_SERVICE_SIGNUP=false

# Telegram opcional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Testnet Binance
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=

# Mainnet Binance
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Seguranca para operacao real
ENABLE_LIVE_EXECUTION=false
LIVE_TRADING_CONFIRMATION=
RUNTIME_REQUIRE_APPROVED_SYMBOL=true
RUNTIME_SYMBOL_APPROVAL_OVERRIDE=false

# Criptografia opcional para credenciais salvas
CREDENTIAL_ENCRYPTION_KEY=

# IA opcional
ENABLE_AI_ASSISTANT=true
AI_MODEL_PATH=data/models/runtime_model.tflite
AI_MODEL_METADATA_PATH=data/models/runtime_model_metadata.json
