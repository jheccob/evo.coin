# Railway injeta PORT automaticamente.
# Escolha: dashboard, bot ou all
RAILWAY_SERVICE_MODE=dashboard

# Runtime principal
TESTNET=true
SYMBOL=BTC/USDT
TIMEFRAME=15m
SINGLE_USER_RUNTIME_EXCHANGE=binanceusdm
SINGLE_USER_RUNTIME_ACCOUNT_ID=railway-primary
SINGLE_USER_RUNTIME_ACCOUNT_ALIAS=Railway Primary
BOT_REQUIRE_LOCAL_CSV_BOOTSTRAP=false
BOT_ALLOW_REST_FALLBACK=true
LEVERAGE=10
POSITION_SIZING_MODE=order_value
ORDER_BALANCE_USAGE_PCT=100
ORDER_VALUE_RISK_CAP=true
RISK_PER_TRADE_PCT=4
POSITION_MARGIN_ALLOCATION_PCT=100
ENFORCE_LIVE_RISK_CAPPED_ALLOCATION=true
MIN_LIVE_ACCOUNT_BALANCE_USDT=0
REQUIRE_LIVE_TRAILING_STOP=true
USE_STRUCTURAL_STOP=true
STRUCTURAL_STOP_LOOKBACK=10
STRUCTURAL_STOP_ATR_BUFFER_MULT=0.25
STRUCTURAL_STOP_MIN_BUFFER_PCT=0.10
USE_ENTRY_HOUR_BLOCKS=true
BLOCKED_SHORT_ENTRY_HOURS_UTC=0,3,6,9,12,13,15,16,17
ENABLE_LONG_REVERSAL_REBOUND=true
LONG_REVERSAL_MIN_DROP_PCT=2.2
LONG_REVERSAL_MIN_BOUNCE_FROM_LOW_PCT=1.2
LONG_REVERSAL_MAX_BOUNCE_FROM_LOW_PCT=5.8
LONG_REVERSAL_MIN_VOLUME_RATIO=1.15
LONG_REVERSAL_MIN_RSI=42
LONG_REVERSAL_MAX_RSI=68
LONG_REVERSAL_HIGH_RSI_THRESHOLD=58
LONG_REVERSAL_HIGH_RSI_MIN_ADX=35
ENABLE_SHORT_REVERSAL_REJECTION=true
SHORT_REVERSAL_MIN_RISE_PCT=2.2
SHORT_REVERSAL_MIN_PULLBACK_FROM_HIGH_PCT=1.1
SHORT_REVERSAL_MAX_PULLBACK_FROM_HIGH_PCT=5.8
SHORT_REVERSAL_MIN_VOLUME_RATIO=1.15
SHORT_REVERSAL_MIN_RSI=45
SHORT_REVERSAL_MAX_RSI=62
SHORT_REVERSAL_LOW_RSI_THRESHOLD=42
SHORT_REVERSAL_LOW_RSI_MIN_ADX=35
SHORT_REVERSAL_BLOCKED_ENTRY_HOURS_UTC=14
AI_ONLINE_LEARNING_ENABLED=true
AI_MEMORY_MIN_TRADES=6
AI_MEMORY_MAX_BIAS=0.12
AI_SETUP_GUARD_ENABLED=true
AI_SETUP_GUARD_MIN_TRADES=8
AI_SETUP_GUARD_LOOKBACK=10
AI_SETUP_GUARD_MAX_CONSECUTIVE_LOSSES=3
AI_SETUP_GUARD_COOLDOWN_SIGNALS=3
MAX_DAILY_REAL_LOSS_PCT=8
MAX_CONSECUTIVE_REAL_LOSSES=3
RISK_DRAWDOWN_WARNING_PCT=25
RISK_DRAWDOWN_BLOCK_PCT=40

# Persistencia
# Em producao, prefira adicionar Railway Postgres e preencher DATABASE_URL.
DATABASE_URL=
DB_PATH=data/trading_bot.db

# Dashboard / acesso
ADMIN_PANEL_PASSWORD=troque-esta-senha
ALLOW_SELF_SERVICE_SIGNUP=false

# Telegram opcional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Testnet Binance
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=

# Mainnet Binance
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Seguranca para operacao real
ENABLE_LIVE_EXECUTION=false
LIVE_TRADING_CONFIRMATION=
RUNTIME_REQUIRE_APPROVED_SYMBOL=true
RUNTIME_SYMBOL_APPROVAL_OVERRIDE=false

# Criptografia opcional para credenciais salvas
CREDENTIAL_ENCRYPTION_KEY=

# IA opcional
ENABLE_AI_ASSISTANT=true
AI_MODEL_PATH=data/models/runtime_model.tflite
AI_MODEL_METADATA_PATH=data/models/runtime_model_metadata.json
